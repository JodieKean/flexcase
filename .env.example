SHOPIFY_SHOP=your_shop_subdomain
SHOPIFY_CLIENT_ID=your_client_id_from_dev_dashboard
SHOPIFY_CLIENT_SECRET=your_client_secret_from_dev_dashboard
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token
# Storefront token must allow cart APIs (e.g. unauthenticated_read_cart, unauthenticated_write_cart).
# Admin app needs write_customers so the server can save cart id on the customer metafield flexcase.headless_cart_id.
SHOPIFY_API_VERSION=2026-04
PORT=5501
SHOPIFY_CA_CLIENT_ID=your_customer_account_client_id
SHOPIFY_CA_CLIENT_SECRET=your_customer_account_client_secret_if_confidential
SHOPIFY_CA_AUTHORIZATION_ENDPOINT=https://shopify.com/authentication/{shop_id}/oauth/authorize
SHOPIFY_CA_TOKEN_ENDPOINT=https://shopify.com/authentication/{shop_id}/oauth/token
SHOPIFY_CA_LOGOUT_ENDPOINT=https://shopify.com/authentication/{shop_id}/logout
SHOPIFY_CA_REDIRECT_URI=http://127.0.0.1:5501/api/customer/oauth/callback
SHOPIFY_CA_SCOPES=openid email customer-account-api:full
FRONTEND_ORIGIN=https://flexcase.my
API_ORIGIN=https://api.flexcase.my
CORS_ALLOWED_ORIGINS=https://flexcase.my

